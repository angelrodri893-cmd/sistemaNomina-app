@model SistemaNominaAPPWeb.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Panel de Control";
}

<div class="container mt-4">
    <h1 class="mb-4">@ViewData["Title"]</h1>

    <!-- Tarjetas de Estadísticas Principales -->
    <div class="row text-center mb-5">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3 shadow">
                <div class="card-header">Vigentes</div>
                <div class="card-body">
                    <h5 class="card-title">@Model.TotalEmployees Empleados Activos</h5>
                    <p class="card-text">Nómina actual</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3 shadow">
                <div class="card-header">Estructura</div>
                <div class="card-body">
                    <h5 class="card-title">@Model.TotalDepartments Departamentos</h5>
                    <p class="card-text">Total de áreas</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-dark bg-warning mb-3 shadow">
                <div class="card-header">Finanzas</div>
                <div class="card-body">
                    <h5 class="card-title">@Model.AverageSalary.ToString("C")</h5>
                    <p class="card-text">Salario Promedio</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Gráfica Chart.js -->
        <div class="col-md-7">
            <div class="card shadow mb-4">
                <div class="card-header text-dark bg-light font-weight-bold">
                    Empleados por Departamento
                </div>
                <div class="card-body">
                    <canvas id="deptChart" width="400" height="250"></canvas>
                </div>
            </div>
        </div>

        <!-- Tabla Últimos Cambios -->
        <div class="col-md-5">
            <div class="card shadow mb-4">
                <div class="card-header text-dark bg-light font-weight-bold">
                    Últimos Cambios Salariales
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (!Model.RecentSalaryChanges.Any())
                        {
                            <li class="list-group-item text-muted">No hay cambios recientes.</li>
                        }
                        else
                        {
                            foreach (var audit in Model.RecentSalaryChanges)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@audit.EmployeeName</strong>
                                        <br/> <small class="text-muted">@audit.DateChanged.ToShortDateString()</small>
                                    </div>
                                    <span class="badge bg-primary rounded-pill">@audit.NewSalary.ToString("c")</span>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var ctx = document.getElementById('deptChart').getContext('2d');
            
            var labels = [
                @foreach(var item in Model.EmployeesPerDepartment)
                {
                    <text>'@item.DepartmentName',</text>
                }
            ];
            
            var data = [
                @foreach(var item in Model.EmployeesPerDepartment)
                {
                    <text>@item.Count,</text>
                }
            ];

            var deptChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Número de Empleados',
                        data: data,
                        backgroundColor: 'rgba(54, 162, 235, 0.6)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    }
                }
            });
        });
    </script>
}
