@model IEnumerable<SistemaNominaAPPWeb.Models.ViewModels.ActiveEmployeeReportViewModel>

@{
    ViewData["Title"] = "Reporte de Empleados Activos";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <a asp-action="ExportActiveEmployeesPdf" class="btn btn-danger">Exportar a PDF</a>
    <a asp-action="ExportActiveEmployeesExcel" class="btn btn-success">Exportar a Excel</a>
</div>

<table class="table table-striped table-bordered mt-4">
    <thead class="table-dark">
        <tr>
            <th>Nombre del Empleado</th>
            <th>Departamento Actual</th>
            <th>Salario Actual</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeName</td>
                <td>@item.DepartmentName</td>
                <td>@item.CurrentSalary.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>
