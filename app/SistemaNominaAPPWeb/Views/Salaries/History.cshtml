@model IEnumerable<SistemaNominaAPPWeb.Models.Salary>

@{
    ViewData["Title"] = "Historial Salarial";
}

<h2>Historial Salarial</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Fecha Inicio</th>
            <th>Fecha Fin</th>
            <th>Monto</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.FromDate.ToShortDateString()</td>
            <td>
                @(item.ToDate.HasValue 
                    ? item.ToDate.Value.ToShortDateString() 
                    : "Actual")
            </td>
            <td>@item.Amount</td>
            <td>
                @if (item.IsActive)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-secondary">Cerrado</span>
                }
            </td>
        </tr>
}
    </tbody>
</table>

<a asp-controller="Employees" asp-action="Index" class="btn btn-primary">
    Volver
</a>